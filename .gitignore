# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
.swc

# production
/build

# misc
.DS_Store
*.pem

# test/verification artifacts (Playwright test runner + MCP browser tool)
/test-results/
/.screenshots/
/.playwright-mcp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.superpowers/

# Transient scheduled-task lock (per-session runtime artifact)
.claude/scheduled_tasks.lock
